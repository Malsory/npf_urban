    "def train_model(X, y):\n",
    "    model = LogisticRegression()\n",
    "\n",
    "    param_grid = {\n",
    "        'max_iter': [1000, 5000, 10000],\n",
    "        'C': np.logspace(9, 18, 32, 64, 128),\n",
    "        'solver': ['newton-cg', 'lbfgs', 'liblinear', 'sag', 'saga']\n",
    "    }\n",
    "    \n",
    "    metrics_dict = {\n",
    "        'test_accuracy': [],\n",
